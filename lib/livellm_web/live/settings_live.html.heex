<Layouts.chat flash={@flash}>
  <div class="flex h-full">
    <%!-- Sidebar --%>
    <.sidebar current_page={:settings} conversations={@conversations} />

    <%!-- Settings main area --%>
    <main id="settings-main" class="flex-1 overflow-y-auto bg-zinc-950">
      <div class="max-w-2xl px-8 py-10">
        <div class="mb-8">
          <h1 class="text-2xl font-semibold text-zinc-100 mb-1">Settings</h1>
          <p class="text-sm text-zinc-400">Manage your LiveLLM preferences and configuration.</p>
        </div>

        <%!-- Placeholder sections --%>
        <div id="settings-sections" class="space-y-6">
          <div id="settings-general" class="rounded-xl border border-zinc-800 bg-zinc-900 p-6">
            <h2 class="text-sm font-semibold text-zinc-200 mb-1">General</h2>
            <p class="text-xs text-zinc-500">General settings will appear here.</p>
          </div>

          <div id="settings-models" class="rounded-xl border border-zinc-800 bg-zinc-900 p-6">
            <h2 class="text-sm font-semibold text-zinc-200 mb-1">Models</h2>
            <p class="text-xs text-zinc-500">Model configuration will appear here.</p>
          </div>

          <div id="settings-connections" class="rounded-xl border border-zinc-800 bg-zinc-900 p-6">
            <h2 class="text-sm font-semibold text-zinc-200 mb-1">Connections</h2>
            <p class="text-xs text-zinc-500">API connection settings will appear here.</p>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layouts.chat>
