<Layouts.chat flash={@flash}>
  <div class="flex h-full">
    <%!-- Sidebar --%>
    <.sidebar current_page={:settings} chats={@chats} current_chat_id={nil} />

    <%!-- Settings main area --%>
    <main id="settings-main" class="flex-1 overflow-y-auto bg-base-100">
      <div class="max-w-2xl px-8 py-10">
        <div class="mb-8">
          <h1 class="text-2xl font-semibold text-base-content mb-1">Settings</h1>
          <p class="text-sm text-base-content/60">
            Manage your LiveLLM preferences and configuration.
          </p>
        </div>

        <div id="settings-sections" class="space-y-6">
          <%!-- General --%>
          <.surface id="settings-general" class="p-6">
            <h2 class="text-sm font-semibold text-base-content mb-4">General</h2>

            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-base-content">Theme</p>
                <p class="text-xs text-base-content/50 mt-0.5">
                  Choose your preferred color scheme.
                </p>
              </div>
              <.theme_selector id="theme-selector" />
            </div>
          </.surface>

          <%!-- Models placeholder --%>
          <.surface id="settings-models" class="p-6" tone={:subtle}>
            <h2 class="text-sm font-semibold text-base-content mb-1">Models</h2>
            <p class="text-xs text-base-content/50">Model configuration will appear here.</p>
          </.surface>

          <%!-- Connections — provider configs --%>
          <.surface
            id="settings-connections"
            class="space-y-6 p-6"
          >
            <div>
              <h2 class="text-sm font-semibold text-base-content mb-1">Connections</h2>
              <p class="text-xs text-base-content/50">
                Configure your LLM provider API credentials.
              </p>
            </div>

            <%!-- Existing configs list --%>
            <div id="provider-configs-list" phx-update="stream" class="space-y-2">
              <div
                :for={{id, config} <- @streams.provider_configs}
                id={id}
                class="flex items-center justify-between gap-4 rounded-2xl border border-base-300/80 bg-base-100/80 px-4 py-3"
              >
                <div class="flex items-center gap-3 min-w-0">
                  <%!-- Provider badge --%>
                  <.status_badge tone={:accent} class="shrink-0 uppercase tracking-wide">
                    {config.provider}
                  </.status_badge>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-base-content truncate">{config.label}</p>
                    <p class="text-xs text-base-content/50 truncate">
                      {config.default_model || "No default model"}
                    </p>
                  </div>
                </div>

                <div class="flex items-center gap-2 shrink-0">
                  <%!-- Enabled indicator --%>
                  <%= if config.enabled do %>
                    <.status_badge tone={:success}>
                      <span class="size-1.5 rounded-full bg-current inline-block"></span> Active
                    </.status_badge>
                  <% else %>
                    <button
                      phx-click="enable_config"
                      phx-value-id={config.id}
                      id={"enable-#{config.id}"}
                      class="text-xs text-base-content/60 hover:text-base-content transition-colors"
                    >
                      Set active
                    </button>
                  <% end %>

                  <button
                    phx-click="delete_config"
                    phx-value-id={config.id}
                    id={"delete-#{config.id}"}
                    data-confirm="Delete this provider config?"
                    class="rounded-lg p-1.5 text-base-content/40 hover:text-red-400 hover:bg-base-100 transition-colors"
                  >
                    <.icon name="hero-trash" class="size-4" />
                  </button>
                </div>
              </div>
            </div>

            <%!-- Add provider form --%>
            <div class="border-t border-base-300 pt-6">
              <h3 class="text-xs font-semibold text-base-content/60 uppercase tracking-wider mb-4">
                Add Provider
              </h3>
              <.form
                for={@form}
                id="provider-config-form"
                phx-submit="save_config"
                class="space-y-4"
              >
                <div class="grid grid-cols-2 gap-4">
                  <.select_input
                    field={@form[:provider]}
                    label="Provider"
                    options={[
                      {"OpenAI (Chat Completions)", "openai"},
                      {"OpenAI (Responses API)", "openai_responses"},
                      {"OpenRouter", "openrouter"},
                      {"Ollama", "ollama"},
                      {"Google", "google"}
                    ]}
                  />
                  <.text_input
                    field={@form[:label]}
                    label="Label"
                    placeholder="e.g. My OpenAI"
                  />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <.text_input
                    field={@form[:default_model]}
                    label="Default Model (optional)"
                    placeholder="e.g. gpt-4.1-mini"
                  />
                  <.text_input
                    field={@form[:api_key]}
                    type="password"
                    label="API Key"
                    placeholder="sk-..."
                  />
                </div>

                <.text_input
                  field={@form[:base_url]}
                  label="Base URL (optional)"
                  placeholder="https://api.openai.com/v1"
                />

                <div class="flex justify-end">
                  <button
                    type="submit"
                    id="save-config-btn"
                    class="px-4 py-2 rounded-lg bg-violet-600 hover:bg-violet-500 text-sm font-medium text-white transition-colors"
                  >
                    Save
                  </button>
                </div>
              </.form>
            </div>
          </.surface>
        </div>
      </div>
    </main>
  </div>
</Layouts.chat>
