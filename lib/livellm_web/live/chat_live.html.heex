<Layouts.chat flash={@flash}>
  <div class="flex h-full">
    <%!-- Sidebar --%>
    <.sidebar current_page={:chat} chats={@chats} current_chat_id={@current_chat_id} />

    <%!-- Main chat area --%>
    <div class="flex flex-col flex-1 min-w-0 bg-base-100 text-base-content">
      <%!-- Chat header --%>
      <header
        id="chat-header"
        class="flex items-center justify-between gap-4 px-6 py-3 border-b border-base-300 shrink-0 bg-base-100"
      >
        <div class="flex min-w-0 items-center gap-3">
          <h1 class="text-sm font-medium text-base-content/60 shrink-0 truncate">
            {if @chat && @chat.title && String.length(@chat.title) > 25,
              do: String.slice(@chat.title, 0, 25) <> "...",
              else: (@chat && @chat.title) || "New Chat"}
          </h1>

          <%= if token_label = Usage.format_total_tokens(@chat_metrics) do %>
            <div id="chat-metrics" class="flex items-center gap-2 text-xs">
              <% token_breakdown = Usage.token_breakdown(@chat_metrics) %>
              <div id="chat-total-tokens-wrapper" class="group relative">
                <span
                  id="chat-total-tokens"
                  class="inline-flex items-center rounded-full border border-emerald-500/20 bg-emerald-500/10 px-2.5 py-1 font-medium text-emerald-200"
                >
                  {token_label}
                </span>

                <div
                  id="chat-tokens-popover"
                  class="pointer-events-none invisible absolute left-0 top-full z-20 mt-2 w-64 rounded-2xl border border-base-300 bg-base-200/95 p-3 text-left text-[11px] text-base-content opacity-0 shadow-2xl shadow-black/10 transition duration-150 group-hover:visible group-hover:opacity-100"
                >
                  <div class="mb-2 flex items-center justify-between gap-3 border-b border-base-300 pb-2">
                    <span class="font-semibold uppercase tracking-[0.18em] text-base-content/60">
                      Token Breakdown
                    </span>
                    <span class="text-emerald-300">{token_label}</span>
                  </div>

                  <div class="space-y-1.5">
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-base-content/60">Input</span>
                      <span>{token_breakdown.input_tokens}</span>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-zinc-400">Cached input</span>
                      <span>{token_breakdown.cached_tokens}</span>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-zinc-400">Uncached input</span>
                      <span>{token_breakdown.uncached_input_tokens}</span>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-zinc-400">Output</span>
                      <span>{token_breakdown.output_tokens}</span>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-zinc-400">Reasoning</span>
                      <span>{token_breakdown.reasoning_tokens}</span>
                    </div>
                  </div>

                  <div class="mt-3 space-y-1.5 border-t border-base-300 pt-2">
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-zinc-400">Input cost</span>
                      <span>{token_breakdown.input_cost || "—"}</span>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-zinc-400">Output cost</span>
                      <span>{token_breakdown.output_cost || "—"}</span>
                    </div>
                    <div class="flex items-center justify-between gap-3 font-medium text-base-content">
                      <span>Total cost</span>
                      <span>{token_breakdown.total_cost || "—"}</span>
                    </div>
                  </div>
                </div>
              </div>

              <%= if cost_label = Usage.format_total_cost(@chat_metrics) do %>
                <span
                  id="chat-total-cost"
                  class="inline-flex items-center rounded-full border border-sky-500/20 bg-sky-500/10 px-2.5 py-1 font-medium text-sky-200"
                >
                  {cost_label}
                </span>
              <% end %>

              <%= if reasoning_label = Usage.format_reasoning_tokens(@chat_metrics) do %>
                <span
                  id="chat-reasoning-tokens"
                  class="inline-flex items-center rounded-full border border-amber-500/20 bg-amber-500/10 px-2.5 py-1 font-medium text-amber-200"
                >
                  {reasoning_label}
                </span>
              <% end %>

              <%= if cached_label = Usage.format_cached_tokens(@chat_metrics) do %>
                <span
                  id="chat-cached-tokens"
                  class="inline-flex items-center rounded-full border border-cyan-500/20 bg-cyan-500/10 px-2.5 py-1 font-medium text-cyan-200"
                >
                  {cached_label}
                </span>
              <% end %>
            </div>
          <% end %>
        </div>

        <%= if @provider_configs == [] do %>
          <.link
            navigate={~p"/settings"}
            id="no-providers-link"
            class="text-xs text-base-content/50 hover:text-base-content/80 transition-colors"
          >
            No providers configured — go to Settings
          </.link>
        <% else %>
          <form
            id="chat-settings-form"
            phx-change="update_chat_settings"
            phx-hook=".ChatSettings"
            data-chat-id={@current_chat_id}
            class="flex items-center gap-2 shrink-0"
          >
            <select
              id="provider-select"
              name="provider_id"
              class="bg-base-200 border border-base-300 rounded-lg px-2 py-1 text-xs text-base-content focus:outline-none focus:border-base-content/30 transition-colors cursor-pointer"
            >
              <option value="">Select provider...</option>
              <%= for p <- @provider_configs do %>
                <option value={p.id} selected={@selected_provider_id == p.id}>
                  {p.label} ({p.provider})
                </option>
              <% end %>
            </select>

            <input
              id="model-input"
              type="text"
              name="model"
              value={@selected_model}
              placeholder="Model..."
              phx-debounce="300"
              phx-hook=".AutosizeInput"
              class="bg-base-200 border border-base-300 rounded-lg px-2 py-1 text-xs text-base-content placeholder-base-content/40 focus:outline-none focus:border-base-content/30 transition-colors min-w-16"
            />

            <select
              id="reasoning-effort-select"
              name="reasoning_effort"
              class="bg-base-200 border border-base-300 rounded-lg px-2 py-1 text-xs text-base-content focus:outline-none focus:border-base-content/30 transition-colors cursor-pointer"
            >
              <option value="">No reasoning</option>
              <%= for effort <- ~w(minimal low medium high xhigh) do %>
                <option value={effort} selected={@selected_reasoning_effort == effort}>
                  {effort}
                </option>
              <% end %>
            </select>

            <label
              id="streaming-label"
              class="flex items-center gap-1.5 text-xs text-base-content/60 cursor-pointer select-none"
            >
              <input
                id="streaming-toggle"
                type="checkbox"
                name="streaming"
                value="true"
                checked={@stream_mode}
                class="accent-violet-500 cursor-pointer"
              /> Stream
            </label>
          </form>
        <% end %>
      </header>
      <script :type={Phoenix.LiveView.ColocatedHook} name=".AutosizeInput">
        export default {
          mounted() {
            this._sizer = document.createElement("span")
            this._sizer.style.cssText =
              "position:fixed;top:0;left:0;visibility:hidden;white-space:pre;pointer-events:none"
            document.body.appendChild(this._sizer)
            this._resize()
            this.el.addEventListener("input", () => this._resize())
          },
          updated() {
            this._resize()
          },
          destroyed() {
            this._sizer.remove()
          },
          _resize() {
            const s = getComputedStyle(this.el)
            this._sizer.style.font = s.font
            this._sizer.style.letterSpacing = s.letterSpacing
            this._sizer.style.padding = s.padding
            this._sizer.textContent = this.el.value || this.el.placeholder || ""
            const minPx = parseFloat(s.minWidth) || 64
            this.el.style.width = Math.max(this._sizer.offsetWidth + 2, minPx) + "px"
          }
        }
      </script>

      <%!-- Messages scroll area --%>
      <div
        id="messages-scroll"
        class="flex-1 overflow-y-auto flex flex-col"
        phx-hook=".ScrollToBottom"
      >
        <div class="mt-auto py-4">
          <div id="messages" phx-update="stream" class="space-y-1">
            <.chat_message :for={{id, msg} <- @streams.messages} id={id} message={msg} />
          </div>

          <%!-- Streaming / thinking indicator --%>
          <%= if not is_nil(@streaming_reasoning) do %>
            <div id="streaming-reasoning" class="flex gap-3 px-6 py-2">
              <div class="size-8 rounded-full shrink-0 flex items-center justify-center bg-amber-600/80 text-white mt-0.5">
                <.icon name="hero-light-bulb" class="size-4" />
              </div>
              <div class="chat-reasoning max-w-[72%] rounded-2xl rounded-tl-sm border px-4 py-3 text-sm leading-relaxed">
                <div class="chat-reasoning-label mb-2 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em]">
                  <span>Thinking</span>
                </div>
                <div id="streaming-reasoning-content" class="whitespace-pre-wrap">
                  {@streaming_reasoning}<span class="chat-reasoning-cursor inline-block w-0.5 h-4 animate-pulse ml-0.5 align-middle"></span>
                </div>
              </div>
            </div>
          <% end %>

          <%= cond do %>
            <% not is_nil(@streaming_content) -> %>
              <div id="streaming-message" class="flex gap-3 px-6 py-3">
                <div class="size-8 rounded-full shrink-0 flex items-center justify-center bg-violet-700 text-white mt-0.5">
                  <.icon name="hero-cpu-chip" class="size-4" />
                </div>
                <div class="max-w-[72%] bg-base-200 text-base-content rounded-2xl rounded-tl-sm px-4 py-3 text-sm leading-relaxed">
                  <.markdown_content
                    markdown={@streaming_content}
                    streaming={true}
                    class="chat-markdown"
                  />
                  <div class="mt-2 flex items-center">
                    <span class="inline-block h-4 w-0.5 animate-pulse bg-base-content/40"></span>
                  </div>
                </div>
              </div>
            <% @waiting -> %>
              <div id="thinking-indicator" class="flex gap-3 px-6 py-3">
                <div class="size-8 rounded-full shrink-0 flex items-center justify-center bg-violet-700 text-white mt-0.5">
                  <.icon name="hero-cpu-chip" class="size-4" />
                </div>
                <div class="bg-base-200 rounded-2xl rounded-tl-sm px-4 py-3 flex items-center gap-1.5">
                  <span class="size-1.5 rounded-full bg-base-content/40 animate-bounce [animation-delay:0ms]">
                  </span>
                  <span class="size-1.5 rounded-full bg-base-content/40 animate-bounce [animation-delay:150ms]">
                  </span>
                  <span class="size-1.5 rounded-full bg-base-content/40 animate-bounce [animation-delay:300ms]">
                  </span>
                </div>
              </div>
            <% true -> %>
          <% end %>
        </div>
      </div>

      <%!-- Input bar --%>
      <div id="input-bar" class="shrink-0 px-4 py-4 border-t border-base-300 bg-base-100">
        <form
          id="message-form"
          phx-submit="send_message"
          class={[
            "flex items-end gap-3 bg-base-200 border rounded-2xl px-4 py-3 transition-colors duration-150",
            @waiting && "border-base-300 opacity-60",
            !@waiting && "border-base-300 focus-within:border-base-content/30"
          ]}
        >
          <textarea
            id="message-input"
            name="message"
            rows="1"
            placeholder={if @waiting, do: "Waiting for response...", else: "Message LiveLLM..."}
            disabled={@waiting}
            class="flex-1 bg-transparent text-sm text-base-content placeholder-base-content/40 resize-none outline-none max-h-40 overflow-y-auto leading-relaxed disabled:cursor-not-allowed"
            phx-hook=".AutoGrow"
          ></textarea>
          <button
            type="submit"
            id="send-btn"
            disabled={@waiting}
            class="size-8 rounded-xl bg-violet-600 hover:bg-violet-500 active:bg-violet-700 flex items-center justify-center transition-colors duration-150 shrink-0 disabled:opacity-40 disabled:cursor-not-allowed"
          >
            <.icon name="hero-arrow-up" class="size-4 text-white" />
          </button>
        </form>
        <p class="text-center text-xs text-base-content/30 mt-2">
          LiveLLM can make mistakes. Verify important info.
        </p>
      </div>
    </div>
  </div>

  <%!-- Persist stream mode globally in localStorage --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatSettings">
    const KEY = "livellm:stream_mode"
    export default {
      mounted() {
        this.handleEvent("save_chat_settings", ({ streaming }) => {
          localStorage.setItem(KEY, JSON.stringify({ streaming }))
        })
        this.restore()
      },
      restore() {
        const saved = localStorage.getItem(KEY)
        if (saved) {
          try { this.pushEvent("restore_chat_settings", JSON.parse(saved)) } catch (_) {}
        }
      }
    }
  </script>

  <%!-- Auto-grow textarea hook --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".AutoGrow">
    export default {
      mounted() {
        this.el.focus()
        this.handleEvent("focus_input", () => this.el.focus())
        this.el.addEventListener("input", () => {
          this.el.style.height = "auto"
          this.el.style.height = this.el.scrollHeight + "px"
        })
        this.el.addEventListener("keydown", (e) => {
          const newline = (e.shiftKey && e.key === "Enter") || (e.ctrlKey && e.key === "j")
          if (newline) {
            e.preventDefault()
            const start = this.el.selectionStart
            const end = this.el.selectionEnd
            this.el.value = this.el.value.slice(0, start) + "\n" + this.el.value.slice(end)
            this.el.selectionStart = this.el.selectionEnd = start + 1
            this.el.dispatchEvent(new Event("input"))
          } else if (e.key === "Enter") {
            e.preventDefault()
            this.el.closest("form").requestSubmit()
          }
        })
      }
    }
  </script>

  <%!-- Scroll messages to bottom on mount/update --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".ScrollToBottom">
    export default {
      mounted() {
        this._pinned = true
        this.el.addEventListener("scroll", () => {
          const { scrollTop, scrollHeight, clientHeight } = this.el
          this._pinned = scrollHeight - scrollTop - clientHeight < 40
        })
        this.scrollToBottom()
      },
      updated() {
        if (this._pinned) this.scrollToBottom()
      },
      scrollToBottom() {
        this.el.scrollTop = this.el.scrollHeight
      }
    }
  </script>
</Layouts.chat>
