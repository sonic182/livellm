<Layouts.chat flash={@flash}>
  <div class="flex h-full">
    <%!-- Sidebar --%>
    <.sidebar current_page={:chat} conversations={@conversations} />

    <%!-- Main chat area --%>
    <div class="flex flex-col flex-1 min-w-0">
      <%!-- Chat header --%>
      <header
        id="chat-header"
        class="flex items-center px-6 py-4 border-b border-zinc-800 shrink-0 bg-zinc-950"
      >
        <h1 class="text-sm font-medium text-zinc-300 truncate">What is Elixir?</h1>
      </header>

      <%!-- Messages scroll area --%>
      <div
        id="messages-scroll"
        class="flex-1 overflow-y-auto py-4"
        phx-hook=".ScrollToBottom"
      >
        <div id="messages" phx-update="stream" class="space-y-1">
          <.chat_message :for={{id, msg} <- @streams.messages} id={id} message={msg} />
        </div>
      </div>

      <%!-- Input bar --%>
      <div id="input-bar" class="shrink-0 px-4 py-4 border-t border-zinc-800 bg-zinc-950">
        <form
          id="message-form"
          phx-submit="send_message"
          class="flex items-end gap-3 bg-zinc-900 border border-zinc-700 rounded-2xl px-4 py-3 focus-within:border-zinc-500 transition-colors duration-150"
        >
          <textarea
            id="message-input"
            name="message"
            rows="1"
            placeholder="Message LiveLLM..."
            class="flex-1 bg-transparent text-sm text-zinc-100 placeholder-zinc-500 resize-none outline-none max-h-40 overflow-y-auto leading-relaxed"
            phx-hook=".AutoGrow"
          ></textarea>
          <button
            type="submit"
            id="send-btn"
            class="size-8 rounded-xl bg-violet-600 hover:bg-violet-500 active:bg-violet-700 flex items-center justify-center transition-colors duration-150 shrink-0"
          >
            <.icon name="hero-arrow-up" class="size-4 text-white" />
          </button>
        </form>
        <p class="text-center text-xs text-zinc-600 mt-2">
          LiveLLM can make mistakes. Verify important info.
        </p>
      </div>
    </div>
  </div>

  <%!-- Auto-grow textarea hook --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".AutoGrow">
    export default {
      mounted() {
        this.el.addEventListener("input", () => {
          this.el.style.height = "auto"
          this.el.style.height = this.el.scrollHeight + "px"
        })
      }
    }
  </script>

  <%!-- Scroll messages to bottom on mount/update --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".ScrollToBottom">
    export default {
      mounted() { this.scrollToBottom() },
      updated() { this.scrollToBottom() },
      scrollToBottom() {
        this.el.scrollTop = this.el.scrollHeight
      }
    }
  </script>
</Layouts.chat>
